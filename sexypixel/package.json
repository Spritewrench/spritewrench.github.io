{
  "name": "renjs-electron-quick-start",
  "version": "1.0.0",
  "productName": "RenJS With Electron Quickstart",
  "description": "RenJS Quickstart ported to use Electron",
  "main": "main.js",
  "electron-packager": "git+https://github.com/electron-userland/electron-packager.git",
  "scripts": {
    "start": "electron .",
    "package-mac": "electron-packager . --overwrite --platform=darwin --arch=x64 --icon=assets/icons/icon.icns --prune=true --out=release-builds",
    "package-win": "electron-packager . GnT_Test --overwrite --platform=win32 --arch=x64 --icon=assets/icons/favicon.ico --prune=true --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName=\"DEMO\" ",
    "package-linux": "electron-packager . electron-tutorial-app --overwrite --asar=true --platform=linux --arch=x64 --icon=assets/icons/icon.png --prune=true --out=release-builds"
  },
  "repository": "https://gitlab.com/lunafromthemoon/RenJSQuickstartElectron",
  "keywords": [
    "Electron",
    "quick",
    "start",
    "RenJS"
  ],
  "author": "lunafromthemoon",
  "license": "CC0-1.0",
  "devDependencies": {
    "electron": "3.0.9"
  },
  "dependencies": {
    "debug": "^4.1.1",
    "greenworks": "git+https://github.com/greenheartgames/greenworks.git"
  }
}
